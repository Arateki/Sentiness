{
  "name": "@sentiness/check-jscpd",
  "version": "0.1.1",
  "description": "Sentiness check that reports copy/paste code duplication via jscpd.",
  "license": "MIT",
  "engines": {
    "node": ">=20.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arateki/Sentiness.git",
    "directory": "packages/checks/jscpd"
  },
  "homepage": "https://github.com/Arateki/Sentiness#readme",
  "bugs": "https://github.com/Arateki/Sentiness/issues",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../../scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ../../../vitest.config.base.ts src"
  },
  "dependencies": {
    "@sentiness/check-sdk": "workspace:*",
    "jscpd": "4.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sentiness/_test-utils": "workspace:*",
    "typescript": "latest",
    "vitest": "latest"
  }
}
