{
  "name": "@sentiness/check-dependency-cruiser",
  "version": "0.1.0",
  "description": "Sentiness check that reports architecture rule violations via dependency-cruiser.",
  "license": "MIT",
  "engines": {
    "node": ">=20.10"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../../scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ../../../vitest.config.base.ts src"
  },
  "dependencies": {
    "@sentiness/check-sdk": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sentiness/_test-utils": "workspace:*",
    "fast-check": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
