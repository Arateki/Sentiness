{
  "name": "@sentiness/check-sdk",
  "version": "0.1.0",
  "description": "Public types and contract for writing Sentiness check plugins.",
  "license": "MIT",
  "engines": {
    "node": ">=20.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arateki/Sentiness.git",
    "directory": "packages/check-sdk"
  },
  "homepage": "https://github.com/Arateki/Sentiness#readme",
  "bugs": "https://github.com/Arateki/Sentiness/issues",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ../../vitest.config.base.ts src"
  },
  "devDependencies": {
    "typescript": "latest",
    "vitest": "latest"
  }
}
