{
  "name": "@sentiness/adapters",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist && cp src/skill-template.md dist/skill-template.md",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ../../vitest.config.base.ts src"
  },
  "dependencies": {
    "@sentiness/check-sdk": "workspace:*"
  },
  "devDependencies": {
    "@sentiness/_test-utils": "workspace:*",
    "@types/node": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
