{
  "name": "@sentiness/adapters",
  "version": "0.1.4",
  "description": "Agent instruction adapters for Sentiness: Claude Code (managed section and skill), Codex, and Gemini.",
  "license": "MIT",
  "engines": {
    "node": ">=20.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arateki/Sentiness.git",
    "directory": "packages/adapters"
  },
  "homepage": "https://github.com/Arateki/Sentiness#readme",
  "bugs": "https://github.com/Arateki/Sentiness/issues",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean-dist.mjs && tsc -p tsconfig.json && mkdir -p dist && cp src/skill-template.md dist/skill-template.md",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ../../vitest.config.base.ts src"
  },
  "dependencies": {
    "@sentiness/check-sdk": "workspace:*"
  },
  "devDependencies": {
    "@sentiness/_test-utils": "workspace:*",
    "@types/node": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
