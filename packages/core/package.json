{
  "name": "@sentiness/core",
  "version": "1.0.0",
  "description": "CLI quality gate for AI coding agents: runs configured checks and emits one normalized, baseline-aware JSON report.",
  "license": "MIT",
  "engines": {
    "node": ">=20.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arateki/Sentiness.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Arateki/Sentiness#readme",
  "bugs": "https://github.com/Arateki/Sentiness/issues",
  "type": "module",
  "files": [
    "dist",
    "schema/report.schema.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ../../vitest.config.base.ts src",
    "test:e2e": "vitest run --config ../../vitest.config.base.ts test/e2e",
    "generate-schema": "pnpm build && node scripts/generate-schema.mjs && pnpm exec biome format --write schema/report.schema.json"
  },
  "dependencies": {
    "@sentiness/adapters": "workspace:*",
    "@sentiness/check-sdk": "workspace:*",
    "cac": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sentiness/_test-utils": "workspace:*",
    "@types/node": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
