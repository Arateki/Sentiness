{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "sentinessVersion": {
      "type": "string"
    },
    "runId": {
      "type": "string"
    },
    "startedAt": {
      "type": "string"
    },
    "completedAt": {
      "type": "string"
    },
    "durationMs": {
      "type": "number",
      "minimum": 0
    },
    "context": {
      "type": "object",
      "properties": {
        "cwd": {
          "type": "string"
        },
        "tier": {
          "type": "string",
          "enum": ["fast", "standard", "slow"]
        },
        "trigger": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "mode": {
          "type": "string",
          "enum": ["diff", "trend", "full"]
        },
        "baseRef": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "headRef": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "changedFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "addedDependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "removedDependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "cwd",
        "tier",
        "trigger",
        "mode",
        "baseRef",
        "headRef",
        "changedFiles",
        "addedDependencies",
        "removedDependencies"
      ],
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "violations", "error"]
        },
        "totals": {
          "type": "object",
          "properties": {
            "error": {
              "type": "number"
            },
            "warning": {
              "type": "number"
            },
            "info": {
              "type": "number"
            }
          },
          "required": ["error", "warning", "info"],
          "additionalProperties": false
        },
        "newInDiff": {
          "type": "object",
          "properties": {
            "error": {
              "type": "number"
            },
            "warning": {
              "type": "number"
            },
            "info": {
              "type": "number"
            }
          },
          "required": ["error", "warning", "info"],
          "additionalProperties": false
        },
        "blocking": {
          "type": "boolean"
        },
        "topIssues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "checksRun": {
          "type": "number"
        },
        "checksSkipped": {
          "type": "number"
        },
        "checksErrored": {
          "type": "number"
        }
      },
      "required": [
        "status",
        "totals",
        "newInDiff",
        "blocking",
        "topIssues",
        "checksRun",
        "checksSkipped",
        "checksErrored"
      ],
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "lint",
              "architecture",
              "test-quality",
              "coverage",
              "security",
              "duplication",
              "complexity",
              "platform"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["ok", "violations", "error", "skipped"]
          },
          "durationMs": {
            "type": "number",
            "minimum": 0
          },
          "metrics": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "string"
                },
                {
                  "type": "boolean"
                }
              ]
            }
          },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "checkId": {
                  "type": "string"
                },
                "ruleId": {
                  "type": "string"
                },
                "severity": {
                  "type": "string",
                  "enum": ["error", "warning", "info"]
                },
                "message": {
                  "type": "string"
                },
                "location": {
                  "type": "object",
                  "properties": {
                    "file": {
                      "type": "string"
                    },
                    "startLine": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    },
                    "startColumn": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    },
                    "endLine": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    },
                    "endColumn": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    },
                    "packageName": {
                      "type": "string"
                    },
                    "packageVersion": {
                      "type": "string"
                    }
                  },
                  "required": ["file"],
                  "additionalProperties": false
                },
                "snippet": {
                  "type": "string"
                },
                "suggestion": {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "enum": ["refactor", "add-test", "upgrade", "remove", "rename", "other"]
                    },
                    "description": {
                      "type": "string"
                    },
                    "command": {
                      "type": "string"
                    }
                  },
                  "required": ["kind", "description"],
                  "additionalProperties": false
                },
                "references": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "fingerprint": {
                  "type": "string",
                  "pattern": "^[a-f0-9]{64}$"
                },
                "introducedInDiff": {
                  "type": "boolean"
                }
              },
              "required": [
                "id",
                "checkId",
                "ruleId",
                "severity",
                "message",
                "location",
                "fingerprint"
              ],
              "additionalProperties": false
            }
          },
          "skipReason": {
            "type": "string"
          },
          "errorMessage": {
            "type": "string"
          },
          "truncated": {
            "type": "object",
            "properties": {
              "total": {
                "type": "number"
              },
              "shown": {
                "type": "number"
              }
            },
            "required": ["total", "shown"],
            "additionalProperties": false
          }
        },
        "required": ["id", "category", "status", "durationMs", "findings"],
        "additionalProperties": false
      }
    },
    "trend": {
      "type": "object",
      "properties": {
        "available": {
          "type": "boolean"
        },
        "regressions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "metric": {
                "type": "string"
              },
              "baselineValue": {
                "type": "number"
              },
              "currentValue": {
                "type": "number"
              },
              "direction": {
                "type": "string",
                "enum": ["higher-is-better", "lower-is-better"]
              }
            },
            "required": ["metric", "baselineValue", "currentValue", "direction"],
            "additionalProperties": false
          }
        },
        "reason": {
          "type": "string"
        }
      },
      "required": ["available"],
      "additionalProperties": false
    },
    "baseline": {
      "type": "object",
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "suppressedFindings": {
          "type": "number"
        }
      },
      "required": ["applied", "path", "suppressedFindings"],
      "additionalProperties": false
    },
    "agentInstructions": {
      "type": "object",
      "properties": {
        "blocking": {
          "type": "boolean"
        },
        "mustFix": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "shouldFix": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "informational": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["blocking", "mustFix", "shouldFix", "informational"],
      "additionalProperties": false
    }
  },
  "required": [
    "schemaVersion",
    "sentinessVersion",
    "runId",
    "startedAt",
    "completedAt",
    "durationMs",
    "context",
    "summary",
    "checks",
    "trend",
    "baseline",
    "agentInstructions"
  ],
  "additionalProperties": false
}
